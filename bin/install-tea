#!/usr/bin/env bash
# Install the Gitea/Forgejo tea CLI into ~/.local/bin (Codeberg-compatible).
set -euo pipefail

TEA_VERSION="${TEA_VERSION:-0.14.2}"
PREFIX="${HOME}/.local/bin"
mkdir -p "${PREFIX}"

arch="$(uname -m)"
case "${arch}" in
  x86_64|amd64) tea_arch="amd64" ;;
  aarch64|arm64) tea_arch="arm64" ;;
  *)
    echo "Unsupported architecture: ${arch}" >&2
    exit 1
    ;;
esac

url="https://dl.gitea.com/tea/${TEA_VERSION}/tea-${TEA_VERSION}-linux-${tea_arch}"
tmp="$(mktemp)"
trap 'rm -f "${tmp}"' EXIT

echo "Downloading tea ${TEA_VERSION} (${tea_arch})..."
curl -fsSL -o "${tmp}" "${url}"
chmod +x "${tmp}"
mv "${tmp}" "${PREFIX}/tea"
trap - EXIT

# Ensure ~/.local/bin is on PATH for this and future shells in the container.
if ! grep -q 'export PATH=.*\.local/bin' "${HOME}/.bashrc" 2>/dev/null; then
  echo 'export PATH="${HOME}/.local/bin:${PATH}"' >> "${HOME}/.bashrc"
fi
export PATH="${HOME}/.local/bin:${PATH}"

tea --version
echo "tea installed to ${PREFIX}/tea"
