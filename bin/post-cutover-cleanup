#!/usr/bin/env bash
# Post-DNS-cutover cleanup helpers (does not disable GitHub Pages for you).
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "${ROOT}"

echo "== Post-cutover checklist =="
echo
echo "1. Verify https://0xtero.hanninen.eu/ (home, blog, /feed.xml, HTTPS)."
echo "2. Disable GitHub Pages: https://github.com/0xtero/0xtero.hanninen.eu/settings/pages"
echo "3. Remove the GitHub-specific CNAME file (Codeberg uses DNS TXT auth):"

if [[ -f CNAME ]]; then
  echo "   git rm CNAME && git commit -m \"Remove GitHub Pages CNAME after Codeberg cutover\""
else
  echo "   (CNAME already absent)"
fi

echo
echo "4. Optionally make Codeberg the primary remote:"
echo "   git remote rename origin github"
echo "   git remote rename codeberg origin"
echo
echo "5. Keep dual-push only if you want a GitHub mirror; otherwise drop github remote later."
echo
echo "This script does not modify git state. Run the git commands above when ready."
