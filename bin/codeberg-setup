#!/usr/bin/env bash
# Create the Codeberg repo (if missing), add the codeberg remote, and push main.
set -euo pipefail

OWNER="${CODEBERG_OWNER:-0xtero}"
REPO="${CODEBERG_REPO:-0xtero.hanninen.eu}"
REMOTE_URL="https://codeberg.org/${OWNER}/${REPO}.git"
REMOTE_NAME="${CODEBERG_REMOTE:-codeberg}"

if ! command -v tea >/dev/null 2>&1; then
  echo "tea not found. Run: bash bin/install-tea" >&2
  exit 1
fi

if ! tea login list --output simple 2>/dev/null | grep -q .; then
  echo "No tea login configured." >&2
  echo "Create a token at https://codeberg.org/user/settings/applications" >&2
  echo "Then: tea login add --name codeberg --url https://codeberg.org --token <TOKEN>" >&2
  echo "      tea login default codeberg" >&2
  exit 1
fi

echo "Ensuring Codeberg repository ${OWNER}/${REPO} exists..."
if tea repos list --owner "${OWNER}" --fields name --output simple 2>/dev/null | grep -qx "${REPO}" \
  || tea repos search "${OWNER}/${REPO}" --output json 2>/dev/null | grep -q "\"full_name\":\"${OWNER}/${REPO}\""; then
  echo "Repository already exists (or is visible)."
else
  # Prefer creating under the logged-in user; --owner only if org.
  logged_in="$(tea login list --output simple 2>/dev/null | awk '$5 == "true" { print $4; exit }')"
  if [[ "${OWNER}" == "${logged_in}" ]] || [[ -z "${logged_in}" ]]; then
    tea repos create \
      --name "${REPO}" \
      --description "Personal site (Jekyll) — Codeberg Pages"
  else
    tea repos create \
      --name "${REPO}" \
      --owner "${OWNER}" \
      --description "Personal site (Jekyll) — Codeberg Pages"
  fi
fi

if git remote get-url "${REMOTE_NAME}" >/dev/null 2>&1; then
  echo "Remote '${REMOTE_NAME}' already set to $(git remote get-url "${REMOTE_NAME}")"
else
  git remote add "${REMOTE_NAME}" "${REMOTE_URL}"
  echo "Added remote '${REMOTE_NAME}' → ${REMOTE_URL}"
fi

branch="$(git rev-parse --abbrev-ref HEAD)"
echo "Pushing ${branch} to ${REMOTE_NAME}..."
git push -u "${REMOTE_NAME}" "${branch}"

echo
echo "Next:"
echo "  1. Enable Forgejo Actions for the repo if prompted by Codeberg."
echo "  2. Confirm the workflow run under Actions."
echo "  3. Open https://${OWNER}.codeberg.page/${REPO}/"
