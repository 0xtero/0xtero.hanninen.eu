#!/usr/bin/env bash
# Verify DNS records needed for Codeberg Pages custom-domain cutover.
set -euo pipefail

DOMAIN="${1:-0xtero.hanninen.eu}"
OWNER="${CODEBERG_OWNER:-0xtero}"
REPO="${CODEBERG_REPO:-0xtero.hanninen.eu}"
ALLOWLIST="_git-pages-forge-allowlist.${DOMAIN}"
EXPECTED_TXT="https://codeberg.org/${OWNER}/${REPO}.git"

resolve() {
  local name="$1" type="$2"
  python3 - "$name" "$type" <<'PY'
import json, sys, urllib.request
name, rtype = sys.argv[1], sys.argv[2]
url = f"https://dns.google/resolve?name={name}&type={rtype}"
data = json.load(urllib.request.urlopen(url))
answers = data.get("Answer") or []
for a in answers:
    print(a.get("data", ""))
if not answers:
    print("(none)")
print(f"TTL_HINT={answers[0].get('TTL') if answers else data.get('Authority', [{}])[0].get('TTL', '?')}")
PY
}

echo "== CNAME ${DOMAIN} =="
resolve "${DOMAIN}" CNAME
echo
echo "== TXT ${ALLOWLIST} (expect: ${EXPECTED_TXT}) =="
resolve "${ALLOWLIST}" TXT
echo
echo "== CAA hanninen.eu =="
resolve "hanninen.eu" CAA
echo
echo "Prep checklist (EasyDNS):"
echo "  1. Lower TTL on ${DOMAIN%%.*} (e.g. 300)."
echo "  2. Add TXT  _git-pages-forge-allowlist.${DOMAIN%%.*}  =  ${EXPECTED_TXT}"
echo "  3. Do NOT change CNAME away from 0xtero.github.io until cutover day."
echo "  4. On cutover: CNAME ${DOMAIN%%.*} → codeberg.page."
