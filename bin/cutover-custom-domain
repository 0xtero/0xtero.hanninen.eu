#!/usr/bin/env bash
# Switch Forgejo Pages deploy from *.codeberg.page preview to the custom domain.
# Run this on cutover day, push to both remotes, then flip DNS CNAME to codeberg.page.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "${ROOT}"
WF="${ROOT}/.forgejo/workflows/pages.yml"

if [[ ! -f "${WF}" ]]; then
  echo "Missing ${WF}" >&2
  exit 1
fi

python3 - <<'PY'
from pathlib import Path
path = Path(".forgejo/workflows/pages.yml")
text = path.read_text()
old = """      - name: Deploy to Codeberg Pages
        uses: https://codeberg.org/git-pages/action@v2
        with:
          # Use repository.name (not repository / owner/repo) — a slash in the
          # site path makes git-pages return "directories nested too deep".
          site: https://${{ forgejo.repository_owner }}.codeberg.page/${{ forgejo.event.repository.name }}/
          token: ${{ forgejo.token }}
          source: _site/
"""
new = """      - name: Deploy to Codeberg Pages
        uses: https://codeberg.org/git-pages/action@v2
        with:
          site: https://0xtero.hanninen.eu/
          server: codeberg.page
          token: ${{ forgejo.token }}
          source: _site/
"""
if old not in text:
    if "site: https://0xtero.hanninen.eu/" in text:
        print("Workflow already targets the custom domain.")
        raise SystemExit(0)
    raise SystemExit("Could not find preview deploy block to replace in pages.yml")
path.write_text(text.replace(old, new, 1))
print("Updated .forgejo/workflows/pages.yml to deploy https://0xtero.hanninen.eu/")
PY

echo
echo "Commit and push to origin + codeberg, then at EasyDNS:"
echo "  CNAME  0xtero  →  codeberg.page."
echo "Ensure TXT exists:"
echo "  _git-pages-forge-allowlist.0xtero  TXT  https://codeberg.org/0xtero/0xtero.hanninen.eu.git"
